# ─── VoiceCursor Concierge backend (Convex) ───────────────────────────────
# Convex deployment (already provisioned).
CONVEX_URL=https://wandering-skunk-190.convex.cloud
# HTTP actions base (…convex.site) — used by Photon / the demo client / curl.
CONVEX_SITE_URL=https://wandering-skunk-190.convex.site

# ── Convex environment variables (set with: npx convex env set KEY value) ──
# These live INSIDE the Convex deployment, not in this file. Listed here for reference.
#
#   API_KEY            shared secret for /photon/* and /mock/* (X-Api-Key header)
#   PHOTON_WEBHOOK_URL  where Convex POSTs proactive outbound sends (teammate's listener)
#   UBER_API_BASE_URL   teammate's Uber connector endpoint; unset → realistic fake quotes
#   DEMO_MODE           "on" (default) routes inbound through the rule-based fallback agent

# ── Local-only (for scripts/tts-helper.ts and scripts/demo.ts) ──
API_KEY=dev-secret-change-me

# ── Local-only (for scripts/photon-listener.ts — run on a Mac, needs Messages.app) ──
# Spectrum project credentials — get from your Spectrum/Photon dashboard.
PROJECT_ID=
PROJECT_SECRET=

# ─── Uber API credentials (for the Uber connector service) ────────────────
# Get these from https://developer.uber.com/dashboard (see setup instructions in README)
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_SERVER_TOKEN=

# OAuth redirect URI registered in the Uber developer dashboard
UBER_REDIRECT_URI=http://localhost:3000/auth/uber/callback
